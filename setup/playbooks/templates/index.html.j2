<!DOCTYPE html>
<html>
<head>
    <title>Hello World – Monitoring Demo</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 0; background: #1a1a2e; color: #eee; }
        .hero {
            background: linear-gradient(135deg, #0f3460 0%, #16213e 50%, #1a1a2e 100%);
            padding: 60px 20px;
            text-align: center;
        }
        .hero img { width: 140px; margin-bottom: 20px; }
        h1 { font-size: 2.4em; margin: 0 0 10px 0; color: #fff; }
        .tagline { color: #a8b2d1; font-size: 1.1em; margin-bottom: 30px; }
        .status-badge {
            display: inline-block;
            background: #28a745;
            color: #fff;
            padding: 8px 24px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.95em;
            letter-spacing: 0.5px;
        }
        .cards {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            max-width: 900px;
            margin: -30px auto 40px auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }
        .card {
            background: #16213e;
            border: 1px solid #0f3460;
            border-radius: 10px;
            padding: 24px;
            width: 240px;
            text-align: center;
        }
        .card-icon { font-size: 2em; margin-bottom: 10px; }
        .card h3 { margin: 0 0 8px 0; color: #e94560; font-size: 1em; }
        .card p { margin: 0; color: #a8b2d1; font-size: 0.85em; line-height: 1.5; }
        .footer {
            text-align: center;
            padding: 30px;
            color: #4a5568;
            font-size: 0.8em;
        }
    </style>
</head>
<body>
    <div class="hero">
        <img src="https://upload.wikimedia.org/wikipedia/commons/7/79/Red_Hat_Logo_2019.svg" alt="Red Hat">
        <h1>Hello World!</h1>
        <p class="tagline">
            {{ ansible_hostname | default('monitoring-demo') }} &middot;
            Managed by Ansible Automation Platform
        </p>
        <span class="status-badge">&#10003; httpd is running</span>
    </div>

    <div class="cards">
        <div class="card">
            <div class="card-icon">&#128202;</div>
            <h3>Prometheus</h3>
            <p>Scraping metrics from this host via Node Exporter every 15 seconds</p>
        </div>
        <div class="card">
            <div class="card-icon">&#128680;</div>
            <h3>AlertManager</h3>
            <p>Fires alerts when httpd goes down and creates ServiceNow incidents</p>
        </div>
        <div class="card">
            <div class="card-icon">&#129302;</div>
            <h3>ALIA</h3>
            <p>Ansible Lightspeed AI analyses diagnostics and provides root cause analysis</p>
        </div>
    </div>

    <div class="footer">
        Monitored by Prometheus &middot; Automated by Event-Driven Ansible &middot; Enriched by Ansible Lightspeed
    </div>
</body>
</html>
