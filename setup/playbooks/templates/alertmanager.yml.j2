global:
  resolve_timeout: 5m

route:
  receiver: servicenow
  group_by:
    - alertname
    - instance
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h

receivers:
  - name: servicenow
    webhook_configs:
      - url: http://localhost:{{ webhook_port }}/webhook
        send_resolved: true
