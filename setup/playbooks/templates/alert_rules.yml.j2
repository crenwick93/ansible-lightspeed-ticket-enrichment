groups:
  - name: systemd_services
    rules:
{% for svc in monitored_services %}
      - alert: ServiceDown_{{ svc | replace('.service', '') }}
        expr: node_systemd_unit_state{name="{{ svc }}", state="active"} == 0
        for: 15s
        labels:
          severity: critical
          service: {{ svc }}
        annotations:
{% raw %}
          summary: "systemd service {{ $labels.name }} is down on {{ $labels.instance }}"
          description: >-
            The systemd service {{ $labels.name }} on host {{ $labels.instance }}
            has been inactive for more than 15 seconds. Immediate attention required.
            This alert was generated by Prometheus AlertManager.
{% endraw %}
{% endfor %}
