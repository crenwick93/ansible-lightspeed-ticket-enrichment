#!/usr/bin/env python3
"""AlertManager -> ServiceNow incident webhook bridge.

Receives POST from AlertManager, maps alert fields to a ServiceNow
incident, and creates it via the Table API.
"""

import base64
import json
import logging
import sys
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler, HTTPServer

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    stream=sys.stdout,
)
log = logging.getLogger("snow-webhook")

SN_INSTANCE = "{{ servicenow_instance }}"
SN_USERNAME = "{{ servicenow_username }}"
SN_PASSWORD = "{{ servicenow_password }}"
LISTEN_PORT = {{ webhook_port }}
CMDB_CI_SYS_ID = "{{ cmdb_ci_sys_id | default('') }}"


def create_incident(alert):
    """POST a new incident to the ServiceNow Table API."""
    labels = alert.get("labels", {})
    annotations = alert.get("annotations", {})

    incident = {
        "short_description": annotations.get(
            "summary", f"Alert: {labels.get('alertname', 'Unknown')}"
        ),
        "description": annotations.get("description", ""),
        "urgency": "1",
        "impact": "1",
        "category": "Software",
    }
    if CMDB_CI_SYS_ID:
        incident["cmdb_ci"] = CMDB_CI_SYS_ID

    url = f"{SN_INSTANCE.rstrip('/')}/api/now/table/incident"
    creds = base64.b64encode(f"{SN_USERNAME}:{SN_PASSWORD}".encode()).decode()
    headers = {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "Authorization": f"Basic {creds}",
    }

    req = urllib.request.Request(
        url, data=json.dumps(incident).encode(), headers=headers, method="POST"
    )
    try:
        with urllib.request.urlopen(req) as resp:
            result = json.loads(resp.read())
            sys_id = result.get("result", {}).get("sys_id", "?")
            number = result.get("result", {}).get("number", "?")
            log.info("Created ServiceNow incident %s (sys_id=%s)", number, sys_id)
    except urllib.error.URLError:
        log.exception("Failed to create ServiceNow incident")
        raise


class WebhookHandler(BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length)
        try:
            data = json.loads(body)
            for alert in data.get("alerts", []):
                if alert.get("status") == "firing":
                    create_incident(alert)
                elif alert.get("status") == "resolved":
                    log.info(
                        "Alert resolved: %s",
                        alert.get("labels", {}).get("alertname"),
                    )
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"OK")
        except Exception:
            log.exception("Failed to process webhook")
            self.send_response(500)
            self.end_headers()
            self.wfile.write(b"error")


if __name__ == "__main__":
    server = HTTPServer(("0.0.0.0", LISTEN_PORT), WebhookHandler)
    log.info("Listening on port %d", LISTEN_PORT)
    server.serve_forever()
